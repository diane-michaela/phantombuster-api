# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# PhantomBuster
PHANTOMBUSTER_API_KEY=your_phantombuster_api_key_here

# Anthropic (for rank_profiles.py)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Airtable
AIRTABLE_PAT=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
AIRTABLE_TABLE_ID=your_airtable_table_id_here

# PhantomBuster agent IDs (find these in the PhantomBuster UI)
PB_EMPLOYEES_EXPORT_ID=your_company_employees_export_phantom_id
PB_PROFILE_ENRICHER_ID=your_profile_scraper_phantom_id
